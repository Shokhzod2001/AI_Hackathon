# Local development — matches docker-compose.yml credentials
DATABASE_URL=postgresql+asyncpg://nm_user:nm_pass@localhost:5432/narkomonitor
REDIS_URL=redis://localhost:6379/0

# Add your Anthropic API key here for AI scanning
ANTHROPIC_API_KEY=

CLAUDE_MODEL=claude-sonnet-4-6
JWT_SECRET_KEY=clearnet-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
AUTO_BLOCK_THRESHOLD=85
DEBUG=false
