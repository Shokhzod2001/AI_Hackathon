# Database
DATABASE_URL=postgresql+asyncpg://nm_user:nm_pass@localhost:5432/narkomonitor
POSTGRES_DB=narkomonitor
POSTGRES_USER=nm_user
POSTGRES_PASSWORD=nm_pass

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Claude AI
ANTHROPIC_API_KEY=sk-ant-api03-...

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# UZINFOCOM
UZINFOCOM_API_KEY=
